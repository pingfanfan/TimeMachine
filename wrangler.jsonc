{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "timemachine",
  "compatibility_date": "2026-05-12",
  "main": "worker/index.js",
  "observability": {
    "enabled": true
  },
  "assets": {
    "directory": "public",
    "binding": "ASSETS"
  },
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "vars": {
    "ZHIHU_OAUTH_APP_ID": "227",
    "ZHIHU_OAUTH_REDIRECT_URI": "https://www.tmark.top/api/auth/callback",
    "ZHIHU_RING_ID": "2029619126742656657"
  }
}
